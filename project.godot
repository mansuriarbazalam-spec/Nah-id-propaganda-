; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited just fine manually with a text editor.

[application]

config/name="Nah Ad Propaganda"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
SanityManager="*res://scripts/autoload/sanity_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
EffectsManager="*res://scripts/autoload/effects_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
SkillTreeManager="*res://scripts/autoload/skill_tree_manager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

